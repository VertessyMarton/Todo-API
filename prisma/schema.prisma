datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  todos      Todo[]
}

model Todo {
    id        Int      @id @default(autoincrement())
    task      String
    completed Boolean  @default(false)
    userId    Int
    user      User     @relation(fields: [userId], references: [id])
}